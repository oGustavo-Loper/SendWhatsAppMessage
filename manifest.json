{
  "manifest_version": 3,
  "name": "Envio de mensagem por WhatsApp",
  "version": "1.0",
  "description": "Abre conversas no WhatsApp Web com mensagem pré-preenchida",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Envio de mensagens por WhatsApp",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["clipboardWrite"]
}
